# MCP server image for trade-alert.
# Packages real API integrations (scripts/mcp_servers/) and the server
# framework (scripts/mcp_server.py).
#
# Build: docker compose --profile mcp build
# Usage: Each service passes its port as a command arg.
#   Servers use real API integrations; graceful degradation if keys missing.

FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi \
    "uvicorn[standard]" \
    httpx \
    hvac \
    tradingview-ta

COPY scripts/mcp_server.py /app/mcp_server.py
COPY scripts/mcp_servers/ /app/mcp_servers/
COPY vault_env_loader.py /app/vault_env_loader.py

EXPOSE 8001-8010

ENTRYPOINT ["python", "mcp_server.py"]
