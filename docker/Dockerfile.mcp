# Lightweight MCP server image for trade-alert.
# Packages scripts/mock_mcp_server.py and runs a single-port
# FastAPI service matching the SSOT §3 MCP contract.
#
# Build: docker compose --profile mcp build
# Usage: Each service passes its port as a command arg.

FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir fastapi uvicorn[standard]

COPY scripts/mock_mcp_server.py /app/mock_mcp_server.py

EXPOSE 8001-8010

ENTRYPOINT ["python", "mock_mcp_server.py"]
