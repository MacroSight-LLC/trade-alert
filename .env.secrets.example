# trade-alert secrets — NEVER commit this file.
# Copy to .env.secrets and fill in your credentials.
# cp .env.secrets.example .env.secrets
#
# These are separated from .env (config) so that non-secret
# tunable values can be safely committed to version control.
# ────────────────────────────────────────────────────────────

# ── Vault Connection ─────────────────────────────────────────
# VAULT_TOKEN must match the token Vault was initialised with.
# vault-init.sh defaults to "dev-root-token" for local dev.
# For production, use a unique token and set it here AND in Vault.
VAULT_ADDR=
VAULT_TOKEN=dev-root-token

# ── API Keys ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=

# ── Postgres ─────────────────────────────────────────────────
POSTGRES_USER=trade_alert
POSTGRES_PASSWORD=

# ── Discord ──────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_ALERT_CHANNEL_ID=
DISCORD_OPS_CHANNEL_ID=
DISCORD_WEBHOOK=

# ── Langfuse ─────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
NEXTAUTH_SECRET=
ENCRYPTION_KEY=
