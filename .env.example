# trade-alert environment configuration (non-secret tunables)
# Copy to .env and adjust as needed.
# For secrets (API keys, passwords, tokens), see .env.secrets.example
#
# ─── SECRETS MANAGEMENT ─────────────────────────────────────
# Option A (Vault — recommended for production):
#   1. Start Vault:  docker compose up vault -d
#   2. Run:  ./scripts/vault-init.sh      (migrates .env.secrets → Vault)
#   3. Keep only VAULT_ADDR, VAULT_TOKEN in .env.secrets and tunables here.
#
# Option B (env files — local dev):
#   Fill in .env.secrets with credentials. Leave VAULT_ADDR empty.
# ─────────────────────────────────────────────────────────────

# ── Connection URLs ─────────────────────────────────────────────
# NOTE: In Docker, override these to use container service names:
#   REDIS_URL=redis://redis:6379
#   DATABASE_URL=postgresql://trade_alert:<password>@postgres:5432/trade_alert
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://trade_alert:password@localhost:5432/trade_alert

# ── Phase 8: Outcome Tracker ───────────────────────────────────
POLYGON_API_KEY=
OUTCOME_WINDOW_HOURS=4
PRICE_POLL_INTERVAL=60

# ── Tunable Thresholds ─────────────────────────────────────────
VIX_RISK_THRESHOLD=20.0
CURVE_RISK_THRESHOLD=-25.0
FALLBACK_EQUITIES=AAPL,MSFT,NVDA,TSLA,SPY,QQQ,AMD,META,AMZN,GOOGL
FALLBACK_CRYPTO=BTC,ETH,SOL,BNB,AVAX
REDIS_SNAPSHOT_TTL=900
MERGER_TOP_N=20

# ── Development / Mock Mode ────────────────────────────────────
# Set MOCK_DATA=1 to use synthetic data instead of real MCP calls
MOCK_DATA=

# ── Langfuse Observability ──────────────────────────────────────
# Self-hosted Langfuse instance (started via docker compose).
LANGFUSE_HOST=http://localhost:3000

# ── Trace Analyzer Thresholds ───────────────────────────────────
TRACE_COST_BUDGET=0.50
TRACE_LATENCY_MAX=120

# ── Langfuse Prompt Management ──────────────────────────────────
# Decision prompts are managed in the Langfuse UI under:
#   • decision-system  (system prompt)
#   • decision-user    (user prompt with {{variables}})
# Prompts are fetched with label="production". If Langfuse is
# unavailable, built-in YAML-equivalent fallbacks are used.
# See: ./scripts/langfuse-setup.sh for initial prompt seeding.
