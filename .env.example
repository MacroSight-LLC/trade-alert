# trade-alert environment variables
# Copy to .env and fill in required values.
#
# ─── SECRETS MANAGEMENT ─────────────────────────────────────
# Option A (Vault — recommended for production):
#   1. Start Vault:  docker compose up vault -d
#   2. Run:  ./scripts/vault-init.sh      (migrates .env → Vault)
#   3. Keep only VAULT_ADDR, VAULT_TOKEN, and tunables below.
#
# Option B (env vars — local dev):
#   Fill in the values below directly. Leave VAULT_ADDR empty.
# ─────────────────────────────────────────────────────────────

# ── Vault Connection (leave empty to use env vars directly) ──
VAULT_ADDR=
VAULT_TOKEN=

# ── Required — no defaults (stored in Vault for production) ──
POSTGRES_USER=trade_alert
POSTGRES_PASSWORD=
DISCORD_BOT_TOKEN=
DISCORD_ALERT_CHANNEL_ID=
DISCORD_OPS_CHANNEL_ID=
FRED_API_KEY=
FINNHUB_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Optional — defaults available ───────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://trade_alert:password@localhost:5432/trade_alert
DISCORD_WEBHOOK=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# HTTPS for local testing (required for IBM Verify redirect URIs)
# SSL_KEYFILE="deployment/certs/localhost.key"
# SSL_CERTFILE="deployment/certs/localhost.crt"

# Optional: E2B sandbox
# E2B_API_KEY="e2b_xxx"

# Copy to .env and fill in your values
# cp .env.example .env

# ── Phase 8: Outcome Tracker ───────────────────────────────────
POLYGON_API_KEY=
OUTCOME_WINDOW_HOURS=4
PRICE_POLL_INTERVAL=60

# ── Tunable Thresholds ─────────────────────────────────────────
VIX_RISK_THRESHOLD=20.0
CURVE_RISK_THRESHOLD=-25.0
FALLBACK_EQUITIES=AAPL,MSFT,NVDA,TSLA,SPY,QQQ,AMD,META,AMZN,GOOGL
FALLBACK_CRYPTO=BTC,ETH,SOL,BNB,AVAX
REDIS_SNAPSHOT_TTL=900
MERGER_TOP_N=20

# ── Development / Mock Mode ────────────────────────────────────
# Set MOCK_DATA=1 to use synthetic data instead of real MCP calls
MOCK_DATA=

# ── Langfuse Observability ──────────────────────────────────────
# Self-hosted Langfuse instance (started via docker compose).
# After first run, create an account at http://localhost:3000
# and copy the API keys here.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
NEXTAUTH_SECRET=
ENCRYPTION_KEY=

# ── Trace Analyzer Thresholds ───────────────────────────────────
TRACE_COST_BUDGET=0.50
TRACE_LATENCY_MAX=120
PROMPT_VERSION=v1.0
