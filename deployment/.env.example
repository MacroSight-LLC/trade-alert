# API keys for deploy-local.sh (used to create k8s secret)
# Copy to deployment/.env or use project root .env

GROQ_API_KEY="gsk-your-groq-api-key"

# For deploy-local-postgres.sh (PostgreSQL with pgvector)
# POSTGRES_PASSWORD="your-secure-password"
MODEL_NAME="openai/gpt-oss-120b"
AGENT_SETTING_CONFIG="settings.groq.toml"

# Or OpenAI
# OPENAI_API_KEY="sk-your-openai-api-key"
# MODEL_NAME="gpt-4o"
# AGENT_SETTING_CONFIG="settings.openai.toml"

